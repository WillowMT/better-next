# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# App URL (no trailing slash, no inline comments)
BETTER_AUTH_URL=http://localhost:3000

# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/better_next

# Optional — enables profile photo file uploads (Vercel Blob)
# Without this, users can still set a profile image via URL.
BLOB_READ_WRITE_TOKEN=
