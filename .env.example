# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Server-side app URL (no trailing slash, no inline comments)
BETTER_AUTH_URL=http://localhost:3000

# Client-side app URL (usually same as BETTER_AUTH_URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL — local Docker default matches docker-compose.yml
DATABASE_URL=postgres://postgres:postgres@localhost:5432/better_next

# Optional — enables profile photo file uploads
# Without this, users can still set a profile image via URL.
BLOB_READ_WRITE_TOKEN=

# Optional — comma-separated host allowlist for pasted profile image URLs
# Example: cdn.example.com,*.images.example.com
PROFILE_IMAGE_ALLOWED_HOSTS=

# Optional — enables Better Auth verification/reset emails in local console logs
# Set to "console" for local development; use a real mail provider in production.
AUTH_EMAIL_DELIVERY=
